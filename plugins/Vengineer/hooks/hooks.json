{
  "description": "Vengineer hooks: language context detection and solution confirmation capture",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/add-language-context.py"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/detect-solution.py"
          }
        ]
      }
    ]
  }
}
